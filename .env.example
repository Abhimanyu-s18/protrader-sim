# ─────────────────────────────────────────────────────────────
# ProTraderSim — Environment Variables Template
# Copy to .env.local and fill in all values before running.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────

# ── DATABASE ──────────────────────────────────────────────────
# Supabase connection pooler URL (for Prisma in serverless/edge)
DATABASE_URL="postgresql://postgres.zmzhhwrhrsjwqrremguv:[YOUR-PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Direct connection URL (for Prisma migrations — bypasses pooler)
DIRECT_URL="postgresql://postgres.zmzhhwrhrsjwqrremguv:[YOUR-PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:5432/postgres"

# Local dev override (Docker Compose)
# DATABASE_URL="postgresql://protrader:protrader_local_dev@localhost:5432/protrader_sim"
# DIRECT_URL="postgresql://protrader:protrader_local_dev@localhost:5432/protrader_sim"

# ── REDIS ─────────────────────────────────────────────────────
REDIS_URL="redis://:protrader_redis_dev@localhost:6379"
# Production: Redis URL from AWS ElastiCache
# REDIS_URL="rediss://[USERNAME]:[PASSWORD]@[HOST]:6379"

# ── JWT ───────────────────────────────────────────────────────
# Generate with: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----
[YOUR PRIVATE KEY HERE]
-----END RSA PRIVATE KEY-----"

JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----
[YOUR PUBLIC KEY HERE]
-----END PUBLIC KEY-----"

JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
JWT_REFRESH_REMEMBER_ME_EXPIRES_IN="30d"

# ── TWELVE DATA ───────────────────────────────────────────────
# Get from: https://twelvedata.com/account/api-keys
TWELVE_DATA_API_KEY="[YOUR-TWELVE-DATA-API-KEY]"
TWELVE_DATA_WS_URL="wss://ws.twelvedata.com/v1/quotes/price"

# ── NOWPAYMENTS ───────────────────────────────────────────────
# Get from: https://nowpayments.io/merchant-dashboard
NOWPAYMENTS_API_KEY="[YOUR-NOWPAYMENTS-API-KEY]"
NOWPAYMENTS_IPN_SECRET="[YOUR-NOWPAYMENTS-IPN-SECRET]"
NOWPAYMENTS_SANDBOX="true"   # Set to "false" in production

# ── RESEND (Email) ────────────────────────────────────────────
# Get from: https://resend.com/api-keys
RESEND_API_KEY="re_[YOUR-RESEND-API-KEY]"
RESEND_FROM_EMAIL="noreply@protrader.com"
RESEND_FROM_NAME="ProTraderSim"

# ── CLOUDFLARE R2 (KYC Document Storage) ─────────────────────
CLOUDFLARE_ACCOUNT_ID="a19efec0ef2e434d6e6f6ed64f80fb23"
CLOUDFLARE_R2_ACCESS_KEY_ID="[YOUR-R2-ACCESS-KEY-ID]"
CLOUDFLARE_R2_SECRET_ACCESS_KEY="[YOUR-R2-SECRET-ACCESS-KEY]"
CLOUDFLARE_R2_BUCKET_NAME="protrader-kyc-docs"
CLOUDFLARE_R2_PUBLIC_URL="https://[YOUR-ACCOUNT-ID].r2.cloudflarestorage.com"

# ── GOOGLE OAUTH ──────────────────────────────────────────────
GOOGLE_CLIENT_ID="[YOUR-GOOGLE-CLIENT-ID].apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="[YOUR-GOOGLE-CLIENT-SECRET]"

# ── FACEBOOK OAUTH ────────────────────────────────────────────
FACEBOOK_APP_ID="[YOUR-FACEBOOK-APP-ID]"
FACEBOOK_APP_SECRET="[YOUR-FACEBOOK-APP-SECRET]"

# ── APP URLs (Next.js public vars — exposed to browser) ───────
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_WS_URL="ws://localhost:3001"
NEXT_PUBLIC_AUTH_URL="http://localhost:3002"
NEXT_PUBLIC_PLATFORM_URL="http://localhost:3003"
NEXT_PUBLIC_APP_NAME="ProTraderSim"
NEXT_PUBLIC_SUPPORT_EMAIL="support@protrader.com"

# Production overrides:
# NEXT_PUBLIC_API_URL="https://api.protrader.com"
# NEXT_PUBLIC_WS_URL="wss://api.protrader.com"

# ── SERVER PORTS ──────────────────────────────────────────────
PORT=3001                    # API server
WEB_PORT=3000                # Public marketing site
AUTH_PORT=3002               # Auth app
PLATFORM_PORT=3003           # Trading platform
ADMIN_PORT=3004              # Admin panel
IB_PORTAL_PORT=3005          # IB portal

# ── RATE LIMITING ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000   # 1 minute
RATE_LIMIT_MAX=100           # requests per window per user
RATE_LIMIT_AUTH_MAX=5        # login attempts per window per IP

# ── BUSINESS RULES ────────────────────────────────────────────
MIN_DEPOSIT_CENTS=20000          # $200.00
MIN_WITHDRAWAL_CENTS=5000        # $50.00
MAX_WITHDRAWAL_CENTS=500000      # $5,000.00
MAX_DAILY_WITHDRAWAL_CENTS=500000
MARGIN_CALL_BPS=10000            # 100.00%
STOP_OUT_BPS=5000                # 50.00%

# ── ENVIRONMENT ───────────────────────────────────────────────
NODE_ENV="development"
LOG_LEVEL="debug"            # debug | info | warn | error

# ── CORS ALLOWED ORIGINS ──────────────────────────────────────
CORS_ORIGINS="http://localhost:3000,http://localhost:3002,http://localhost:3003,http://localhost:3004,http://localhost:3005"
