# ProTraderSim API Environment Configuration
# ⚠️  SECURITY: Copy values to .env.local, keep .env.local in .gitignore, and NEVER commit real secrets.
# For development: Use .env.local with fake/test values. For CI/CD: Set real values as GitHub Secrets.
# Copy this file to .env.local and fill in the values for local development
# For GitHub CI/CD, set these values as GitHub Secrets/Variables instead

# ============================================
# Application Configuration
# ============================================
NODE_ENV=development
PORT=4000
LOG_LEVEL=debug

# ============================================
# Frontend URLs (NEXT_PUBLIC - exposed to browser)
# ============================================
# Local: http://localhost:3002
# Staging: https://platform-staging.railway.app
# Production: https://app.protrader-sim.com
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000

# ============================================
# Database (PostgreSQL 17)
# ============================================
# Local: postgresql://protrader:protrader_local_dev@localhost:5432/protrader_dev
# Test CI: postgresql://protrader:test_password@localhost:5432/protrader_test
# Staging/Prod: Get from Supabase or RDS dashboard
# 
# DATABASE_URL: Application connection pool (PgBouncer) for normal queries
#   Often routes through a connection pooler or proxy (faster, multiplexed)
# DIRECT_URL: Direct connection bypassing all pooling - REQUIRED for migrations
#   Prisma migrations don't work with transaction pooling; use this direct endpoint
DATABASE_URL=postgresql://user:password@pooler-host:6432/dbname
DIRECT_URL=postgresql://user:password@direct-host:5432/dbname

# ============================================
# Cache (Redis 7)
# ============================================
# Local: redis://localhost:6379
# Staging/Prod: Get from ElastiCache or Railway Redis dashboard
REDIS_URL=redis://host:6379

# ============================================
# Authentication (JWT RS256)
# ============================================
# IMPORTANT: Use RSA key pair (RS256), NOT symmetric key
# Generate 2048-bit RSA key pair (PKCS#8 format):
#   openssl genpkey -algorithm RSA -out jwt-private.pem -pkeyopt rsa_keygen_bits:2048
#   openssl pkey -in jwt-private.pem -pubout -out jwt-public.pem
# Then run: cat jwt-private.pem | sed ':a;N;$!ba;s/\n/\\n/g'
# Include the \n characters in the env var for proper newline escaping

JWT_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nMIIEpAIBAAKCAQEA...\n...\n-----END PRIVATE KEY-----
JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nMIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8A...\n...\n-----END PUBLIC KEY-----

# Token expiration times
JWT_EXPIRES_IN=24h
REFRESH_TOKEN_EXPIRES_IN=7d

# ============================================
# Payments (NowPayments - Crypto Deposits/Withdrawals)
# ============================================
# Sandbox: https://sandbox.nowpayments.io/dashboard
# Production: https://nowpayments.io/dashboard
NOWPAYMENTS_API_KEY=xxx
NOWPAYMENTS_IPN_SECRET=xxx
NOWPAYMENTS_API_URL=https://api.nowpayments.io

# ============================================
# Market Data (Twelve Data)
# ============================================
# Free tier: https://twelvedata.com (7 API calls/min, 800/day)
# Get API key and WebSocket URL from dashboard
TWELVE_DATA_API_KEY=REPLACE_WITH_ACTUAL_KEY
TWELVE_DATA_WS_URL=wss://ws.twelvedata.com/v1/quotes/price

# ============================================
# Email Service (Resend - Transactional Email)
# ============================================
# Get API key from: https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key
RESEND_FROM_EMAIL=noreply@protrader-sim.com

# ============================================
# File Storage (Cloudflare R2 - KYC Documents)
# ============================================
# Create R2 bucket from Cloudflare dashboard → R2
# Create API token with "Edit" permissions
CLOUDFLARE_R2_ACCOUNT_ID=your_account_id
CLOUDFLARE_R2_ACCESS_KEY_ID=your_access_key
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your_secret_key
CLOUDFLARE_R2_BUCKET_NAME=protrader-kyc-documents-dev

# ============================================
# SMTP (Local Email Testing - Optional for local dev)
# ============================================
# Local: Mailhog SMTP on 0.0.0.0:1025
# Web UI: http://localhost:8025
# Staging/Prod: Use Resend or SES
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=

# ============================================
# Turborepo Remote Caching (CI/CD Only)
# ============================================
# Get from: https://vercel.com/teams/settings/tokens
# Used for GitHub Actions CI caching
TURBO_TOKEN=your_turbo_token
TURBO_TEAM=your_turbo_team

# ============================================
# AWS Credentials (Optional — only required for AWS ECS/S3 deployments)
# ============================================
# Optional for local dev (leave blank); only set when deploying to AWS ECS or using S3. Production uses Cloudflare R2 for file storage.
# Get credentials from: AWS IAM Console → Users → Security credentials
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=

# ============================================
# Railway (Staging Deployments)
# ============================================
# Get from Railway account → Tokens
# For local dev: Leave blank (only needed in CI/CD)
RAILWAY_TOKEN=...

# ============================================
# Vercel (Frontend Deployments)
# ============================================
# Get from Vercel → Account Settings → Tokens
# For local dev: Leave blank (only needed in CI/CD)
VERCEL_TOKEN=...
VERCEL_ORG_ID=...

# ============================================
# Health Check URLs (Deployment Validation)
# ============================================
# Staging: https://api-staging.railway.app/health
# Production: https://api.protrader-sim.com/health
STAGING_API_URL=https://api-staging.railway.app
PROD_API_URL=https://api.protrader-sim.com