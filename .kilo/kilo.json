{
  "$schema": "https://app.kilo.ai/config.json",
  "mcp": {
    "context7": {
      "type": "local",
      "command": ["npx", "@upstash/context7-mcp@2.1.8"],
      "environment": {
        "DEFAULT_MINIMUM_TOKENS": "${DEFAULT_MINIMUM_TOKENS:-8000}"
      }
    },
    "memory": {
      "type": "local",
      "command": ["npx", "@modelcontextprotocol/server-memory@2026.1.26"]
    },
    "sequentialthinking": {
      "type": "local",
      "command": ["npx", "@modelcontextprotocol/server-sequential-thinking@2025.12.18"]
    },
    "cloudflare": {
      "type": "local",
      "command": ["npx", "mcp-remote@0.1.38", "https://observability.mcp.cloudflare.com/sse"]
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@0.0.38"]
    },
    "filesystem": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/Users/krishan/Developer/protrader-sim"
      ]
    }
  },
  "agent": {
    "code-reviewer": {
      "mode": "primary",
      "description": "Code Reviewer",
      "prompt": "file:./prompts/code-reviewer.md",
      "permission": {
        "read": "allow",
        "bash": "allow",
        "edit": "deny",
        "mcp": "deny"
      }
    },
    "code-simplifier": {
      "mode": "primary",
      "description": "Code Simplifier",
      "prompt": "file:./prompts/code-simplifier.md",
      "permission": {
        "read": "allow",
        "edit": "allow",
        "bash": "allow",
        "mcp": "allow"
      }
    },
    "code-skeptic": {
      "mode": "primary",
      "description": "Code Skeptic",
      "prompt": "file:./prompts/code-skeptic.md",
      "permission": {
        "read": "allow",
        "edit": {
          "\\.(md|mdc|mdx)$": "allow",
          "*": "deny"
        },
        "bash": "allow",
        "mcp": "allow"
      }
    },
    "docs-specialist": {
      "mode": "primary",
      "description": "Documentation Specialist",
      "prompt": "You are a technical writing expert specializing in clear, comprehensive documentation. You excel at explaining complex concepts simply and creating well-structured docs.\n\n\nFocus on clarity, proper formatting, and comprehensive examples. Always check for broken links and ensure consistency in tone and style.\n",
      "permission": {
        "read": "allow",
        "bash": "allow",
        "edit": {
          "\\.(md|mdx|txt|rst|adoc)$|README$|CHANGELOG$": "allow",
          "*": "deny"
        },
        "mcp": "deny"
      }
    },
    "frontend-specialist": {
      "mode": "primary",
      "description": "Frontend Specialist",
      "prompt": "You are a frontend developer expert in React, TypeScript, and modern CSS. You focus on creating intuitive user interfaces and excellent user experiences.\n\n\nPrioritize accessibility, responsive design, and performance. Use semantic HTML and follow React best practices.\n",
      "permission": {
        "read": "allow",
        "bash": "allow",
        "edit": {
          "\\.(tsx?|jsx?|css|scss|less|html|vue)$": "allow",
          "*": "deny"
        },
        "mcp": "deny"
      }
    },
    "test-engineer": {
      "mode": "primary",
      "description": "Test Engineer",
      "prompt": "You are a QA engineer and testing specialist focused on writing comprehensive tests, debugging failures, and improving code coverage.\n\n\nPrioritize test readability, comprehensive edge cases, and clear assertion messages. Always consider both happy path and error scenarios.\n",
      "permission": {
        "read": "allow",
        "bash": "allow",
        "edit": {
          "\\.(test|spec)\\.(js|ts|jsx|tsx)$": "allow",
          "*": "deny"
        },
        "mcp": "deny"
      }
    }
  }
}
