      "Bash(NODE_PATH=${NODE_BIN_PATH})",
      "Bash($NODE_PATH/node ${PROJECT_ROOT}/apps/api/node_modules/typescript/bin/tsc --version)",
      "Bash($NODE_PATH/node ${PROJECT_ROOT}/apps/api/node_modules/typescript/bin/tsc -p ${PROJECT_ROOT}/apps/api/tsconfig.json --noEmit)",
      "Bash(${NODE_BIN_PATH} ${PROJECT_ROOT}/node_modules/typescript/bin/tsc --version)",
      "Bash(PATH=\"${NODE_BIN_PATH}:$PATH\" node -e \"console.log(''node works'')\")",
      "Bash(PATH=\"${NODE_BIN_PATH}:$PATH\")",
      "Bash(node --eval \"require(''child_process'').execSync(''corepack pnpm --version'', {stdio:''inherit''})\")",
      "Bash(PATH=\"${NODE_BIN_PATH}:$PATH\" corepack pnpm --filter @protrader/api typecheck)",
