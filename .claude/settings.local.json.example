      "Bash(${NPM_BIN} --version)",
      "Bash(NODE_BIN=${NODE_BIN_PATH})",
      "Bash($NODE_BIN --version)",
      "Read(/Users/${USERNAME}/Developer/protrader-sim/lib/node_modules/**)",
      "Bash(NODE=${NODE_BIN_PATH})",
      "Bash($NODE ${PROJECT_ROOT}/node_modules/.bin/tsc -p ${PROJECT_ROOT}/apps/api/tsconfig.json --noEmit)",
      "Bash($NODE ${PROJECT_ROOT}/apps/api/node_modules/typescript/bin/tsc -p ${PROJECT_ROOT}/apps/api/tsconfig.json --noEmit)",
      "Bash($NODE ${PROJECT_ROOT}/node_modules/typescript/bin/tsc -p ${PROJECT_ROOT}/apps/api/tsconfig.json --noEmit)",
      "Bash($NODE ${PROJECT_ROOT}/apps/api/node_modules/typescript/bin/tsc --version)",
